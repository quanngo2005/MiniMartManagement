# Copy this file to .env, then replace every CHANGE_ME value before use.
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Server=host.docker.internal,1433;Database=MiniMartDB;User Id=sa;Password=CHANGE_ME_SQL_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true
Jwt__SecretKey=CHANGE_ME_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
Jwt__Issuer=MiniMart
Jwt__Audience=MiniMart
Vnpay__TmnCode=CHANGE_ME_VNPAY_TMN_CODE
Vnpay__HashSecret=CHANGE_ME_VNPAY_HASH_SECRET
Vnpay__ReturnUrl=http://localhost:5173/payment-success
