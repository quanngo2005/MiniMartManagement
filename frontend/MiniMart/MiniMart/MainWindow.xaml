<Window x:Class="MiniMart.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniMart.Views"
        xmlns:viewmodels="clr-namespace:MiniMart.ViewModels"
        mc:Ignorable="d"
        Title="Phần mềm POS MiniMart" Height="1080" Width="1920" WindowState="Maximized"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main Body -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER: TASKBAR ================= -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Tab Active -->
                <Border Background="#EEF2FF" BorderBrush="#4F46E5" BorderThickness="0,0,0,2" Padding="15,10" Margin="0,0,10,0" CornerRadius="4,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Order 1" FontWeight="Bold" Foreground="#4F46E5" Margin="0,0,10,0"/>
                        <TextBlock Text="✕" Foreground="#4F46E5" Cursor="Hand"/>
                    </StackPanel>
                </Border>
                <!-- Tab Inactive -->
                <Border Padding="15,10" Margin="0,0,10,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Order 2" Foreground="#64748B" Margin="0,0,10,0"/>
                        <TextBlock Text="✕" Foreground="#64748B"/>
                    </StackPanel>
                </Border>
                <Button Content="+" Width="35" Height="35" Background="Transparent" BorderThickness="0" FontSize="20" Foreground="#64748B" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ================= MAIN BODY (8:2) ================= -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7.5*"/>
                <!-- Cột bên trái -->
                <ColumnDefinition Width="2.5*"/>
                <!-- Cột bên phải -->
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: TÌM KIẾM & DANH SÁCH SẢN PHẨM -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,20,0" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20">
                        <Grid>
                            <TextBox FontSize="16" Foreground="#334155" BorderThickness="0" VerticalAlignment="Center" Text="Search products..."/>
                        </Grid>
                    </Border>

                    <!-- DataGrid Món hàng -->
                    <DataGrid Grid.Row="1" Margin="20" AutoGenerateColumns="False" HeadersVisibility="Column" 
          Background="White" BorderThickness="0" RowHeight="60" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
          ItemsSource="{Binding CartItems}">

                        <DataGrid.Columns>
                            <!-- Tên món -->
                            <DataGridTextColumn Header="Item Name" Width="*" Binding="{Binding Name}" FontSize="16"/>

                            <!-- Đơn giá -->
                            <DataGridTextColumn Header="Unit Price" Width="120" Binding="{Binding Price, StringFormat={}{0:N0}}" FontSize="16"/>

                            <!-- Số lượng (Có ô nhập TextBox) -->
                            <DataGridTemplateColumn Header="Qty" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Nút Giảm (-) -->
                                            <Button Content="-" Command="{Binding DecreaseCommand}" Width="30" Height="30" Background="#F1F5F9" BorderThickness="0" FontWeight="Bold"/>

                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="30" TextAlignment="Center" VerticalContentAlignment="Center" Margin="5,0"/>

                                            <!-- Nút Tăng (+) -->
                                            <Button Content="+" Command="{Binding IncreaseCommand}" Width="30" Height="30" Background="#F1F5F9" BorderThickness="0" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Thành tiền -->
                            <DataGridTextColumn Header="Total" Width="120" Binding="{Binding Total, StringFormat={}{0:N0}}" FontSize="16" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- CỘT PHẢI: KHÁCH HÀNG & THANH TOÁN -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Tìm KH -->
                    <RowDefinition Height="Auto"/>
                    <!-- Info KH -->
                    <RowDefinition Height="*"/>
                    <!-- Khoảng trống -->
                    <RowDefinition Height="Auto"/>
                    <!-- Thanh toán -->
                </Grid.RowDefinitions>

                <!-- Search Khách hàng -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <TextBox FontSize="14" BorderThickness="0" Text="Find customer..."/>
                </Border>

                <!-- Panel Customer Info -->
                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Tiêu đề + Nút Edit -->
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Customer Info" FontWeight="Bold" FontSize="18" Foreground="#1E293B"/>
                            <Button Command="{Binding OpenEditCustomerCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="✏️ Edit" Foreground="#4F46E5" FontSize="14"/>
                            </Button>
                        </Grid>

                        <!-- Thông tin -->
                        <TextBlock Text="{Binding CustomerName, StringFormat=Name: {0}}" FontSize="15" Foreground="#334155" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CustomerPhone, StringFormat=Phone: {0}}" FontSize="15" Foreground="#334155" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CustomerPoints, StringFormat=Points: {0:N0}}" FontSize="15" Foreground="#334155" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Input dùng điểm -->
                        <TextBlock Text="Loyalty points to use:" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Text="{Binding LoyaltyPointsToUse, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Panel Checkout (Bottom) -->
                <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Tài chính -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="SubTotal" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Text="{Binding SubTotal, StringFormat={}{0:N0} VND}" FontSize="16" Foreground="#1E293B" FontWeight="Medium" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Discount" FontSize="16" Foreground="#64748B"/>
                            <!-- Hiện dấu trừ trước số tiền -->
                            <TextBlock Text="{Binding Discount, StringFormat=- {0:N0} VND}" FontSize="16" Foreground="#EF4444" FontWeight="Medium" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Background="#E2E8F0" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Final Amount" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding FinalAmount, StringFormat={}{0:N0} VND}" FontSize="24" FontWeight="Black" Foreground="#4F46E5" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Payment Dropdown -->
                        <TextBlock Text="Payment Method" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                        <ComboBox Height="45" Margin="0,0,0,15" SelectedIndex="0" VerticalContentAlignment="Center" FontSize="16" Padding="10,0">
                            <ComboBoxItem Content="Cash"/>
                            <ComboBoxItem Content="VNPay"/>
                        </ComboBox>

                        <!-- Nút Checkout -->
                        <!-- Nút Checkout -->
                        <Button Content="Checkout" Command="{Binding CheckoutCommand}" Height="60" Background="#4F46E5" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ================= LỚP PHỦ POPUP THANH TOÁN QR CODE ================= -->
        <Grid Grid.Row="1" Background="#B2000000" Visibility="{Binding IsCheckoutPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="450" Height="550" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel Margin="30">
                    <TextBlock Text="Thanh toán VNPay" FontSize="28" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Khách hàng quét mã QR dưới đây để thanh toán" FontSize="16" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Khung giả lập mã QR Code -->
                    <Border Width="250" Height="250" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="8">
                        <TextBlock Text="[MÃ QR ĐƯỢC TẠO TỪ API SẼ HIỂN THỊ Ở ĐÂY]" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" Padding="20"/>
                    </Border>

                    <!-- Hiển thị lại số tiền cần thanh toán cho khách xem -->
                    <TextBlock Text="{Binding FinalAmount, StringFormat=Số tiền: {0:N0} VND}" FontSize="22" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Center" Margin="0,25,0,0"/>

                    <Button Content="Hủy giao dịch" Command="{Binding ClosePopupCommand}" Margin="0,25,0,0" Height="50" Background="#F1F5F9" Foreground="#EF4444" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= LỚP PHỦ POPUP EDIT KHÁCH HÀNG ================= -->
        <Grid Grid.Row="1" Background="#B2000000" Visibility="{Binding IsEditCustomerPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="400" Height="350" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel Margin="30">
                    <TextBlock Text="Cập nhật Khách Hàng" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Tên khách hàng" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TempCustomerName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Số điện thoại" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TempCustomerPhone, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,25"/>
                    
                    <!-- Chia làm 2 nút bấm -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="Hủy" Command="{Binding CloseEditCustomerCommand}" Height="45" Background="#F1F5F9" Foreground="#64748B" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Button Grid.Column="2" Content="Lưu lại" Command="{Binding SaveEditCustomerCommand}" Height="45" Background="#4F46E5" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>