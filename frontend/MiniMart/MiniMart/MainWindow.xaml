<Window x:Class="MiniMart.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniMart.Views"
        xmlns:viewmodels="clr-namespace:MiniMart.ViewModels"
        mc:Ignorable="d"
        Title="Phần mềm POS MiniMart" Height="1080" Width="1920" WindowState="Maximized"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Main Body -->
        </Grid.RowDefinitions>

        <!-- ================= HEADER: TASKBAR ================= -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                
                <!-- Ca làm Tab -->
                <Button Command="{Binding ShowShiftTabCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Name="TabBorder" Padding="15,10" CornerRadius="4,4,0,0" BorderThickness="0,0,0,2">
                                <TextBlock Name="TabText" Text="Ca làm" FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsShiftTabActive}" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="#EEF2FF"/>
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4F46E5"/>
                                    <Setter TargetName="TabText" Property="Foreground" Value="#4F46E5"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsShiftTabActive}" Value="False">
                                    <Setter TargetName="TabBorder" Property="Background" Value="Transparent"/>
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="Transparent"/>
                                    <Setter TargetName="TabText" Property="Foreground" Value="#64748B"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- List of Order Tabs -->
                <ItemsControl ItemsSource="{Binding OrderTabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ShowOrderTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Name="TabBorder" Padding="15,10" CornerRadius="4,4,0,0" BorderThickness="0,0,0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Name="TabText" Text="{Binding TabName}" FontWeight="Bold" Margin="0,0,10,0"/>
                                                <Button Content="✕" 
                                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#64748B" Cursor="Hand"
                                                        FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF2FF"/>
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4F46E5"/>
                                                <Setter TargetName="TabText" Property="Foreground" Value="#4F46E5"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add New Tab Button -->
                <Button Command="{Binding AddNewTabCommand}" Content="+" Width="35" Height="35" Background="Transparent" BorderThickness="0" FontSize="20" Foreground="#64748B" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- ================= MAIN BODY ================= -->
        <Grid Grid.Row="1" Margin="20">
            <!-- Order Grid -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShiftTabActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7.5*"/>
                    <!-- Cột bên trái -->
                    <ColumnDefinition Width="2.5*"/>
                    <!-- Cột bên phải -->
                </Grid.ColumnDefinitions>

                <!-- CỘT TRÁI: TÌM KIẾM & DANH SÁCH SẢN PHẨM -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,20,0" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Bar -->
                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20">
                        <Grid>
                            <TextBox FontSize="16" Foreground="#334155" BorderThickness="0" VerticalAlignment="Center" 
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Search products..." Foreground="#94A3B8" FontSize="16" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                    
                    <!-- Search Results Popup (Overlay over DataGrid) -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding SearchResults}" Panel.ZIndex="100"
                             BorderBrush="#E2E8F0" BorderThickness="1" Background="White"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <!-- BoolToVis converter doesn't work for int directly, so we can use a Style trigger instead for better accuracy -->
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchResults.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProductName}" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SellingPrice, StringFormat={}{0:N0}}" FontSize="16" Foreground="#4F46E5" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="Add" Command="{Binding DataContext.AddProductToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="#4F46E5" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- DataGrid Món hàng -->
                    <DataGrid Grid.Row="1" Margin="20" AutoGenerateColumns="False" HeadersVisibility="Column" 
          Background="White" BorderThickness="0" RowHeight="60" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
          ItemsSource="{Binding ActiveTab.CartItems}">

                        <DataGrid.Columns>
                            <!-- Tên món -->
                            <DataGridTextColumn Header="Item Name" Width="*" Binding="{Binding Name}" FontSize="16"/>

                            <!-- Đơn giá -->
                            <DataGridTextColumn Header="Unit Price" Width="120" Binding="{Binding Price, StringFormat={}{0:N0}}" FontSize="16"/>

                            <!-- Số lượng (Có ô nhập TextBox) -->
                            <DataGridTemplateColumn Header="Qty" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Nút Giảm (-) -->
                                            <Button Content="-" Command="{Binding DecreaseCommand}" Width="30" Height="30" Background="#F1F5F9" BorderThickness="0" FontWeight="Bold"/>

                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="30" TextAlignment="Center" VerticalContentAlignment="Center" Margin="5,0"/>

                                            <!-- Nút Tăng (+) -->
                                            <Button Content="+" Command="{Binding IncreaseCommand}" Width="30" Height="30" Background="#F1F5F9" BorderThickness="0" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Thành tiền -->
                            <DataGridTextColumn Header="Total" Width="120" Binding="{Binding Total, StringFormat={}{0:N0}}" FontSize="16" FontWeight="Bold"/>

                            <!-- Xóa -->
                            <DataGridTemplateColumn Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Remove">
                                            <TextBlock Text="❌" FontSize="16" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

                <!-- CỘT PHẢI: KHÁCH HÀNG & THANH TOÁN -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Khách hàng -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <Border Background="White" CornerRadius="8" Padding="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                            </Border.Effect>
                            <Grid>
                                <TextBox FontSize="14" BorderThickness="0" Text="{Binding CustomerSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Find customer by phone..." Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CustomerSearchQuery}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Dropdown ListBox -->
                        <ListBox ItemsSource="{Binding CustomerSearchResults}" 
                                 BorderBrush="#E2E8F0" BorderThickness="1" Background="White"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Margin="0,5,0,0" MaxHeight="150">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CustomerSearchResults.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch">
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding FullName}" FontSize="15" Foreground="#1E293B" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" FontSize="14" Foreground="#64748B" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                <!-- Panel Customer Info -->
                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab.CustomerId}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Tiêu đề + Nút Edit -->
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Customer Info" FontWeight="Bold" FontSize="18" Foreground="#1E293B"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Command="{Binding OpenEditCustomerCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0">
                                    <TextBlock Text="✏️ Edit" Foreground="#4F46E5" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding ClearCustomerCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="❌" Foreground="#EF4444" FontSize="16" FontWeight="Bold"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Thông tin -->
                        <TextBlock Text="{Binding ActiveTab.CustomerName, StringFormat=Name: {0}}" FontSize="15" Foreground="#334155" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ActiveTab.CustomerPhone, StringFormat=Phone: {0}}" FontSize="15" Foreground="#334155" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ActiveTab.CustomerPoints, StringFormat=Points: {0:N0}}" FontSize="15" Foreground="#334155" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Input dùng điểm -->
                        <TextBlock Text="Loyalty points to use:" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                        <TextBox Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Text="{Binding ActiveTab.LoyaltyPointsToUse, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Panel Checkout (Bottom) -->
                <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Tài chính -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="SubTotal" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Text="{Binding ActiveTab.SubTotal, StringFormat={}{0:N0} VND}" FontSize="16" Foreground="#1E293B" FontWeight="Medium" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Discount" FontSize="16" Foreground="#64748B"/>
                            <!-- Hiện dấu trừ trước số tiền -->
                            <TextBlock Text="{Binding ActiveTab.Discount, StringFormat=- {0:N0} VND}" FontSize="16" Foreground="#EF4444" FontWeight="Medium" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Background="#E2E8F0" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Final Amount" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding ActiveTab.FinalAmount, StringFormat={}{0:N0} VND}" FontSize="24" FontWeight="Black" Foreground="#4F46E5" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Tiền khách đưa & Tiền thối -->
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Amount Given" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBox Width="120" Height="40" Padding="10,0" FontSize="16" FontWeight="Medium" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" HorizontalAlignment="Right" Text="{Binding ActiveTab.AmountGiven, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"/>
                        </Grid>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Change" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveTab.ChangeAmount, StringFormat={}{0:N0} VND}" FontSize="18" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Payment Dropdown -->
                        <!-- Ẩn VNPay theo yêu cầu -->
                        <TextBlock Text="Payment Method" FontSize="13" Foreground="#64748B" Margin="0,0,0,5"/>
                        <ComboBox Height="45" Margin="0,0,0,15" SelectedIndex="0" VerticalContentAlignment="Center" FontSize="16" Padding="10,0">
                            <ComboBoxItem Content="Cash"/>
                        </ComboBox>

                        <!-- Nút Checkout -->
                        <!-- Nút Checkout -->
                        <Button Content="Checkout" Command="{Binding CheckoutCommand}" Height="60" Background="#4F46E5" Foreground="White" FontSize="20" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid> <!-- End Right Column -->
        </Grid> <!-- End Order Grid -->

            <!-- Shift Info Grid -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsShiftTabActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <Border Background="White" CornerRadius="12" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#D1D5DB" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Thông tin Ca Làm Việc" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tên ca:" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentShift.ShiftName}" FontSize="16" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ngày làm việc:" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentShift.StartTime, StringFormat='dd/MM/yyyy'}" FontSize="16" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,10,0,20"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Số tiền đầu ca (Start Cash):" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentShift.StartCash, StringFormat={}{0:N0} VND}" FontSize="16" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Số đơn hàng hiện tại:" FontSize="16" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalOrders}" FontSize="16" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Số tiền hiện tại (Ước tính):" FontSize="16" Foreground="#4F46E5" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding CurrentCash, StringFormat={}{0:N0} VND}" FontSize="20" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </Grid> <!-- End Shift Info Grid -->
        </Grid>

        <!-- ================= LỚP PHỦ POPUP THANH TOÁN QR CODE ================= -->
        <Grid Grid.Row="1" Background="#B2000000" Visibility="{Binding IsCheckoutPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="450" Height="550" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel Margin="30">
                    <TextBlock Text="Thanh toán VNPay" FontSize="28" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Khách hàng quét mã QR dưới đây để thanh toán" FontSize="16" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Khung giả lập mã QR Code -->
                    <Border Width="250" Height="250" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="8">
                        <TextBlock Text="[MÃ QR ĐƯỢC TẠO TỪ API SẼ HIỂN THỊ Ở ĐÂY]" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" Padding="20"/>
                    </Border>

                    <!-- Hiển thị lại số tiền cần thanh toán cho khách xem -->
                    <TextBlock Text="{Binding FinalAmount, StringFormat=Số tiền: {0:N0} VND}" FontSize="22" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Center" Margin="0,25,0,0"/>

                    <Button Content="Hủy giao dịch" Command="{Binding ClosePopupCommand}" Margin="0,25,0,0" Height="50" Background="#F1F5F9" Foreground="#EF4444" FontSize="18" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= LỚP PHỦ POPUP EDIT KHÁCH HÀNG ================= -->
        <Grid Grid.Row="1" Background="#B2000000" Visibility="{Binding IsEditCustomerPopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="400" Height="350" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.4"/>
                </Border.Effect>
                <StackPanel Margin="30">
                    <TextBlock Text="Cập nhật Khách Hàng" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Tên khách hàng" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TempCustomerName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Số điện thoại" FontSize="14" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding TempCustomerPhone, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,25"/>
                    
                    <!-- Chia làm 2 nút bấm -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Content="Hủy" Command="{Binding CloseEditCustomerCommand}" Height="45" Background="#F1F5F9" Foreground="#64748B" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Button Grid.Column="2" Content="Lưu lại" Command="{Binding SaveEditCustomerCommand}" Height="45" Background="#4F46E5" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>